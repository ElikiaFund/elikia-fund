EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Google Sign-In — "Web" OAuth client ID from Google Cloud Console (needed for the idToken flow, even on native).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Google Sign-In — "iOS" OAuth client ID from Google Cloud Console. Required on iOS: without it (and without a
# GoogleService-Info.plist), RNGoogleSignin cannot determine the client ID and throws at configure() time.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Facebook — only read by app.config.js at build/prebuild time (baked into
# Info.plist/AndroidManifest), not needed in the JS bundle at runtime.
FACEBOOK_APP_ID=
FACEBOOK_CLIENT_TOKEN=
